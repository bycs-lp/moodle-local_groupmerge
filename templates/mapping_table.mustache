{{!
    @template local_groupmerge/mapping_table

    Renders a table of group merge mappings.

    Example context (json):
    {
        "courseid": 1,
        "canaddmapping": true,
        "mappings": [
            {
                "targetgroup": {
                    "id": 1,
                    "name": "Target Group A"
                },
                "sourcegroups": [
                    {"id": 10, "name": "Source Group 1"},
                    {"id": 11, "name": "Source Group 2"}
                ],
                "typename": "Subset",
                "typeicon": "fa-right-to-bracket"
            }
        ]
    }
}}

<div id="local_groupmerge-mapping-table" data-courseid="{{courseid}}">
{{^canaddmapping}}
<div class="alert alert-warning d-flex align-items-center flex-column gap-3">
    <div>{{#str}} notenoughgroups, local_groupmerge {{/str}}</div>
    <div><a href="{{config.wwwroot}}/group/index.php?id={{courseid}}" class="btn btn-secondary">{{#str}} managegroups, local_groupmerge {{/str}}</a></div>
</div>
{{/canaddmapping}}
{{#canaddmapping}}
<div class="d-flex justify-content-end mb-2">
    <button type="button" class="btn btn-primary" data-action="addmapping"
            aria-label="{{#str}} addmapping, local_groupmerge {{/str}}"
            title="{{#str}} addmapping, local_groupmerge {{/str}}">
        {{#pix}} t/add, core {{/pix}} {{#str}} addmapping, local_groupmerge {{/str}}
    </button>
</div>
<div class="table-responsive">
<table class="table table-bordered table-striped w-100">
    <colgroup>
        <col style="width: 40%">
        <col style="width: 40%">
        <col>
        <col>
    </colgroup>
    <thead>
        <tr>
            <th scope="col">{{#str}} targetgroup, local_groupmerge {{/str}}</th>
            <th scope="col">{{#str}} sourcegroups, local_groupmerge {{/str}}</th>
            <th scope="col" class="text-center text-nowrap">
                {{#str}} mappingtype, local_groupmerge {{/str}}
                {{#helpicon}}{{> core/help_icon}}{{/helpicon}}
            </th>
            <th scope="col" class="text-nowrap">{{#str}} actions {{/str}}</th>
        </tr>
    </thead>
    <tbody>
        {{#mappings}}
        <tr>
            <td>
                <span data-local_groupmerge-groupid="{{targetgroup.id}}">{{targetgroup.name}}</span>
            </td>
            <td>
                {{#sourcegroups}}
                    <div><span data-local_groupmerge-groupid="{{id}}">{{name}}</span></div>
                {{/sourcegroups}}
            </td>
            <td class="text-center text-nowrap">
                <i class="icon fa-solid {{typeicon}} fa-fw" title="{{typename}}" role="img" aria-label="{{typename}}"></i>
            </td>
            <td class="text-nowrap">
                <a href="#" data-action="edit" data-local_groupmerge-targetgroupid="{{targetgroup.id}}"
                   aria-label="{{#str}} edit {{/str}}" title="{{#str}} edit {{/str}}">
                    {{#pix}} t/edit, core, {{#str}} edit {{/str}} {{/pix}}
                </a>
                <a href="#" data-action="delete" data-local_groupmerge-targetgroupid="{{targetgroup.id}}"
                   aria-label="{{#str}} delete {{/str}}" title="{{#str}} delete {{/str}}">
                    {{#pix}} t/delete, core, {{#str}} delete {{/str}} {{/pix}}
                </a>
            </td>
        </tr>
        {{/mappings}}
        {{^mappings}}
        <tr>
            <td colspan="4">{{#str}} nomappings, local_groupmerge {{/str}}</td>
        </tr>
        {{/mappings}}
    </tbody>
</table>
</div>
{{/canaddmapping}}
</div>
