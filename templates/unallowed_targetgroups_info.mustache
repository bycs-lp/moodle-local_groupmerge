{{!
    @template local_groupmerge/unallowed_targetgroups_info

    Renders a list of disallowed target groups grouped by reason.

    Example context (json):
    {
        "groups_by_reason": [
            {
                "reason": "Reserved by another plugin",
                "groupnames": [
                    {"name": "Group A"},
                    {"name": "Group B", "last": true}
                ]
            },
            {
                "reason": "Group has too many members",
                "groupnames": [
                    {"name": "Group C", "last": true}
                ]
            }
        ]
    }
}}
<ul class="text-warning mb-0">
    {{#groups_by_reason}}
    <li><strong>{{#groupnames}}{{name}}{{^last}}, {{/last}}{{/groupnames}}</strong>: {{reason}}</li>
    {{/groups_by_reason}}
</ul>

